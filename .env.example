# MongoDB (Railway MongoDB plugin or Atlas connection string)
MONGODB_URI=mongodb://user:pass@host:27017
MONGODB_DB=renewal_intelligence

# Salesforce connected app (OAuth2 client credentials flow)
SF_INSTANCE_URL=https://yourorg.my.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# LeadIQ Data API
LEADIQ_API_KEY=
LEADIQ_BASE_URL=https://api.leadiq.com

# Clay — table webhook source URL (dispatch target)
CLAY_WEBHOOK_URL=
# Shared secret Clay must send back on the callback (query param ?secret=)
CLAY_CALLBACK_SECRET=

# Tavily
TAVILY_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Slack incoming webhook for #renewal-intel-alerts
SLACK_WEBHOOK_URL=

# Protects /api/cron/* and /api/enrich/* (cron runner sends Authorization: Bearer)
CRON_SECRET=
