# MongoDB (Railway MongoDB plugin or Atlas connection string)
MONGODB_URI=mongodb://user:pass@host:27017
MONGODB_DB=renewal_intelligence

# Salesforce connected app (OAuth2 client credentials flow)
SF_INSTANCE_URL=https://yourorg.my.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# Apollo.io — single provider for enrichment, job-change detection,
# and new-stakeholder discovery
APOLLO_API_KEY=
# Optional: comma-separated ICP titles for stakeholder discovery
# APOLLO_ICP_TITLES=CMO,VP Marketing,Director of Ecommerce,Head of Retention

# Tavily (industry briefings)
TAVILY_API_KEY=

# Anthropic (industry briefings)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Slack incoming webhook for #renewal-intel-alerts
SLACK_WEBHOOK_URL=
# Optional: separate webhook for operational alerts (failed runs). Falls back
# to SLACK_WEBHOOK_URL when unset.
SLACK_OPS_WEBHOOK_URL=

# Protects /api/cron/* and /api/enrich/* (cron runner sends Authorization: Bearer)
CRON_SECRET=
